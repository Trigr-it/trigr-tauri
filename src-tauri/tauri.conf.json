{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Trigr",
  "version": "0.1.25",
  "identifier": "com.nodescaffold.trigr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Trigr",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://github.com https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../assets/icons/tray-icon.png": "icons/tray-icon.png"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwOTU0Q0IwN0ZDRjUxNzQKUldSMFVjOS9zRXlWWUNQeHJzcVZXQzBIT0hLcjRRaTVadU0xMklHRW9zWlFjcHBWVnZVbXE4ZzYK",
      "endpoints": [
        "https://github.com/Trigr-it/trigr-tauri/releases/latest/download/latest.json"
      ]
    }
  }
}
